# ---------------------------------------------------------------------------
# Allowlist: ignore almost everything; only scripts + small project files track
# ---------------------------------------------------------------------------
# After changing this, run:
#   git rm -r --cached .
#   git add .
#   git status
# so Git drops previously tracked large files (data/, outputs/, etc.).

# Ignore all files everywhere
*

# Keep traversing into directories (required for un-ignore below)
!*/

# Repo root — small text / config only (add more !/file if needed)
!/.gitignore
!/README.md
!/requirements.txt

# Code and small supporting assets
!/scripts/
!/scripts/**

!/config/
!/config/**

!/tests/
!/tests/**

!/notebooks/
!/notebooks/**

# Python noise inside allowed trees
**/__pycache__/
*.py[cod]
*.pyo
*.pyd

# OS / editor
.DS_Store
.cursor/
.vscode/

# Large GDC / MC3 downloads (e.g. mc3.v0.2.8.PUBLIC.maf.gz ~700MB) — fetch locally, do not commit
data/raw/mc3/
**/*.PUBLIC.maf.gz
